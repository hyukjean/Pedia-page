# ── AI provider ──────────────────────────────────────────────
# Set at least one key. If PEDIA_PROVIDER is unset, the first provider
# with a key wins, in this order: gemini → openai → anthropic.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: force a provider ("gemini" | "openai" | "anthropic")
PEDIA_PROVIDER=

# Optional: override the routing table (see lib/providers.ts for defaults)
PEDIA_ROOT_MODEL=
PEDIA_CARD_MODEL=
PEDIA_EMBED_MODEL=

# Optional: serve knowledge cards from a *different* (cheaper) provider
# than root answers. e.g. root on Anthropic, cards on Gemini Flash-Lite.
PEDIA_CARD_PROVIDER=

# ── Database (optional — app runs fully without it) ─────────
# Supabase project → Settings → API. Enables the semantic cache,
# card persistence, token logging, and public /c/[slug] pages.
# Run supabase/schema.sql in the SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sign-in (optional — needs the database above) ───────────
# Same Supabase project: URL is identical to SUPABASE_URL; the anon
# ("publishable") key sits next to the service-role key. Enables email
# magic-link sign-in, per-user exploration history, and personalized
# landing suggestions. Leave empty → anonymous mode, no sign-in UI.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Similarity threshold for semantic cache hits (cosine, 0–1)
PEDIA_CACHE_THRESHOLD=0.90

# Canonical site URL for share links / OG metadata (default: https://pedia.page)
NEXT_PUBLIC_SITE_URL=

# ── BYOK (users bring their own API key) ─────────────────────
# Server-side secret for AES-256-GCM encryption of stored user keys.
# Generate: openssl rand -hex 32 · never rotate casually (stored keys
# become undecryptable). Empty → the BYOK UI is disabled.
PEDIA_KEY_SECRET=

# ── Rate limits (per hour; generation calls only, cache hits free) ──
# strong = answers/synthesis/export · cheap = cards/recommend
PEDIA_LIMIT_ANON_STRONG=8
PEDIA_LIMIT_ANON_CHEAP=40
PEDIA_LIMIT_FREE_STRONG=20
PEDIA_LIMIT_FREE_CHEAP=120
PEDIA_LIMIT_PLUS_STRONG=200
PEDIA_LIMIT_PLUS_CHEAP=1000
PEDIA_LIMIT_BYOK_STRONG=500
PEDIA_LIMIT_BYOK_CHEAP=2000
